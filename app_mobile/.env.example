# Control Access Mobile App - Environment Configuration
# Copia este archivo como .env y actualiza los valores

# IP del servidor Laravel
# Para desarrollo local: http://localhost:8000
# Para red local: http://192.168.X.X:8000
REACT_APP_API_BASE_URL=http://192.168.1.100:8000/api

# Timeout de conexión (en milisegundos)
REACT_APP_API_TIMEOUT=8000

# Modo debug
REACT_APP_DEBUG=false

# Nombre de la app
REACT_APP_NAME=Control Access Visitor System
